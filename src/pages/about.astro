---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { categories } from '../data/categories';
import { site } from '../data/site';

const siteUrl = Astro.site ?? new URL('http://localhost:4321');
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    name: `${site.name}について`,
    mainEntity: {
      '@type': 'Person',
      name: site.author.name,
      description: `${site.name} 運営者`,
      url: new URL('/about', siteUrl).href,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl.href },
      { '@type': 'ListItem', position: 2, name: 'このサイトについて', item: new URL('/about', siteUrl).href },
    ],
  },
];
---

<BaseLayout
  title={`このサイトについて | ${site.name}`}
  description={`${site.name}は、ガジェットとインテリアを通して暮らしが少し豊かになる体験を届けるライフスタイルメディアです。`}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-reading">
    <Breadcrumb items={[{ name: 'ホーム', href: '/' }, { name: 'このサイトについて' }]} />

    <header class="text-center">
      <p class="font-display text-xs font-semibold uppercase tracking-[0.2em] text-accent-600 dark:text-accent-300">
        About
      </p>
      <h1 class="mt-3 text-2xl font-bold leading-relaxed tracking-tight text-ink-900 sm:text-3xl dark:text-cream">
        帰りたくなる毎日を。
      </h1>
    </header>

    <div
      class="prose prose-neutral mt-12 max-w-none leading-loose dark:prose-invert prose-headings:font-bold prose-headings:tracking-tight prose-a:text-accent-700 dark:prose-a:text-accent-300"
    >
      <p>
        「かえりたくなる部屋」は、ガジェットとインテリアを通して、
        暮らしが少し豊かになる体験を届けるライフスタイルメディアです。
      </p>
      <p>
        ここは、商品を紹介するだけのサイトではありません。
        「便利だから」ではなく、<strong>“毎日が少し心地よくなるか”</strong>という視点で、
        実際に使ってよかったモノや、心地よい部屋づくりの工夫を綴っています。
      </p>

      <h2>大切にしていること</h2>
      <ul>
        <li><strong>正直であること</strong> — 良かったところも、気になったところも、できるだけそのままお伝えします。</li>
        <li><strong>余白を大切にすること</strong> — モノを増やすより、心地よさが増える選び方を。</li>
        <li><strong>暮らしの目線であること</strong> — スペックではなく、毎日の体験を起点に考えます。</li>
      </ul>

      <h2>発信するテーマ</h2>
      <p>次のカテゴリを中心に発信しています。</p>
    </div>

    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
      {
        categories.map((cat) => (
          <a
            href={`/category/${cat.slug}/`}
            class="group flex items-center gap-2 rounded-xl border border-line bg-surface px-4 py-3 text-sm font-medium text-ink-700 transition hover:border-accent-300 hover:text-accent-700 dark:border-night-line dark:bg-night-surface dark:text-cream dark:hover:border-accent-700 dark:hover:text-accent-300"
          >
            <span class="text-lg">{cat.emoji}</span>
            {cat.name}
          </a>
        ))
      }
    </div>

    <section class="mt-14 rounded-2xl border border-line bg-surface p-6 sm:p-8 dark:border-night-line dark:bg-night-surface">
      <h2 class="text-lg font-bold text-ink-900 dark:text-cream">運営者</h2>
      <p class="mt-3 text-sm leading-loose text-ink-600 dark:text-cream-dim">
        {site.author.name}｜{site.name} 運営者。<br />
        ガジェットとインテリアが好きで、「帰りたくなる部屋」を日々アップデートしています。
        レビュー依頼・ご感想は<a href="/contact" class="text-accent-700 underline-offset-2 hover:underline dark:text-accent-300">お問い合わせ</a>からどうぞ。
      </p>
    </section>
  </div>
</BaseLayout>
