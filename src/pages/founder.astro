---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { categories } from '../data/categories';
import { site, activeSocials } from '../data/site';

const siteUrl = Astro.site ?? new URL('http://localhost:4321');
const hasSocial = activeSocials().length > 0;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    name: `${site.name} 運営者について`,
    mainEntity: {
      '@type': 'Person',
      '@id': `${siteUrl.href}#person`,
      name: site.author.name,
      jobTitle: site.author.role,
      description: `${site.name} の運営者。ガジェットとインテリアを通して、暮らしが少し豊かになる体験を届けている。`,
      url: new URL('/founder/', siteUrl).href,
      ...(activeSocials().length > 0 ? { sameAs: activeSocials().map((s) => s.url) } : {}),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl.href },
      { '@type': 'ListItem', position: 2, name: '運営者について', item: new URL('/founder/', siteUrl).href },
    ],
  },
];
---

<BaseLayout
  title={`運営者について | ${site.name}`}
  description={`${site.name}を運営する${site.author.name}が、なぜこのメディアを始めたのか。大切にしている考え方についてお伝えします。`}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-reading">
    <Breadcrumb items={[{ name: 'ホーム', href: '/' }, { name: '運営者について' }]} />

    <header class="text-center">
      <p class="font-display text-xs font-semibold uppercase tracking-[0.2em] text-accent-600 dark:text-accent-300">
        Founder
      </p>
      <h1 class="mt-3 text-2xl font-bold leading-relaxed tracking-tight text-ink-900 sm:text-3xl dark:text-cream">
        なぜ「かえりたくなる部屋」を<br class="hidden sm:block" />始めたのか。
      </h1>
    </header>

    <div class="prose prose-neutral mt-12 max-w-none leading-loose dark:prose-invert prose-headings:font-bold prose-headings:tracking-tight prose-a:text-accent-700 dark:prose-a:text-accent-300">
      <p>
        はじめまして。「かえりたくなる部屋」を運営している{site.author.name}です。
      </p>
      <p>
        毎日の仕事や家事を終えて、家に帰る。そんな何気ない時間が、少し楽しみになる部屋をつくりたい。
        このメディアは、そんな思いから生まれました。
      </p>
      <p>
        これまでSNSで、ガジェットやインテリア、収納のアイデアを発信してきました。
        けれど「実際に使ってどうだったか」「どんな人に向くのか」といった話は、
        短い投稿だけでは伝えきれない。だからこそ、自分の体験をじっくり残せる場所をつくろうと考えました。
      </p>

      <h2>このメディアが大切にしていること</h2>
      <p>ここは、商品を売るための場所ではありません。モノを通して、暮らしが少し豊かになる体験を届けたい。その一心で運営しています。</p>
      <ul>
        <li><strong>正直であること</strong> — 良かったところも、気になったところも、そのままお伝えします。</li>
        <li><strong>余白を大切にすること</strong> — モノを増やすより、心地よさが増える選び方を。</li>
        <li><strong>暮らしの目線であること</strong> — スペックではなく、毎日の体験を起点に考えます。</li>
      </ul>

      <h2>選ぶときの、たったひとつの基準</h2>
      <p>
        紹介するモノは、便利かどうかではなく、
        <strong>“毎日が少し心地よくなるか”</strong>だけを基準に選んでいます。
        その視点で綴った記事が、あなたの部屋づくりやモノ選びの、ささやかなヒントになれば嬉しいです。
      </p>
    </div>

    <!-- 運営者カード -->
    <section class="mt-14 rounded-2xl border border-line bg-surface p-6 sm:p-8 dark:border-night-line dark:bg-night-surface">
      <div class="flex items-start gap-5">
        <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-accent-100 text-2xl dark:bg-night-line">
          🌿
        </div>
        <div class="min-w-0">
          <p class="text-lg font-bold text-ink-900 dark:text-cream">{site.author.name}</p>
          <p class="mt-0.5 text-sm text-ink-500 dark:text-cream-dim">{site.author.role}</p>
          <p class="mt-3 text-sm leading-loose text-ink-600 dark:text-cream-dim">
            ガジェットとインテリアが好きで、「帰りたくなる部屋」を日々アップデート中。
            レビュー依頼・ご感想は<a href="/contact/" class="text-accent-700 underline-offset-2 hover:underline dark:text-accent-300">お問い合わせ</a>からどうぞ。
          </p>
          {hasSocial && <SocialLinks variant="labeled" class="mt-4" />}
        </div>
      </div>
    </section>

    <!-- カテゴリ導線 -->
    <div class="mt-10">
      <p class="mb-3 text-sm font-medium text-ink-500 dark:text-cream-dim">発信しているテーマ</p>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
        {
          categories.map((cat) => (
            <a
              href={`/category/${cat.slug}/`}
              class="group flex items-center justify-center rounded-xl border border-line bg-surface px-4 py-3 text-center text-sm font-medium text-ink-700 transition hover:border-accent-300 hover:text-accent-700 dark:border-night-line dark:bg-night-surface dark:text-cream dark:hover:border-accent-700 dark:hover:text-accent-300"
            >
              {cat.name}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</BaseLayout>
