---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import CategoryIcon from '../../components/CategoryIcon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { categories } from '../../data/categories';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return categories.map((cat) => ({
    params: { category: cat.slug },
    props: {
      cat,
      posts: posts
        .filter((p) => p.data.category === cat.slug)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { cat, posts } = Astro.props;

const siteUrl = Astro.site ?? new URL('http://localhost:4321');
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl.href },
      { '@type': 'ListItem', position: 2, name: '記事一覧', item: new URL('/blog/', siteUrl).href },
      { '@type': 'ListItem', position: 3, name: cat.name, item: new URL(`/category/${cat.slug}/`, siteUrl).href },
    ],
  },
];
---

<BaseLayout
  title={`${cat.name}の記事 | ${site.name}`}
  description={`${cat.name}の記事一覧。${cat.description}（${site.name}）`}
  jsonLd={jsonLd}
  noindex={posts.length === 0}
>
  <Breadcrumb
    items={[{ name: 'ホーム', href: '/' }, { name: '記事一覧', href: '/blog/' }, { name: cat.name }]}
  />

  <header class="mb-8 text-center">
    <CategoryIcon slug={cat.slug} class="mx-auto h-14 w-14 text-ink-900 dark:text-cream" />
    <h1 class="mt-3 text-2xl font-bold tracking-tight text-ink-900 sm:text-3xl dark:text-cream">
      {cat.name}
    </h1>
    <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-ink-600 dark:text-cream-dim">
      {cat.description}
    </p>
    <p class="mt-1.5 text-xs text-ink-500 dark:text-cream-dim">{posts.length}件の記事</p>
  </header>

  <!-- カテゴリ切り替え -->
  <nav class="mb-12 flex flex-wrap justify-center gap-2" aria-label="カテゴリ">
    <a
      href="/blog/"
      class="rounded-full border border-line px-4 py-1.5 text-sm font-medium text-ink-600 transition hover:border-accent-300 hover:text-accent-700 dark:border-night-line dark:text-cream-dim dark:hover:border-accent-700 dark:hover:text-accent-300"
    >
      すべて
    </a>
    {
      categories.map((c) => (
        <a
          href={`/category/${c.slug}/`}
          class:list={[
            'rounded-full px-4 py-1.5 text-sm font-medium transition',
            c.slug === cat.slug
              ? 'bg-ink-900 text-paper dark:bg-cream dark:text-night'
              : 'border border-line text-ink-600 hover:border-accent-300 hover:text-accent-700 dark:border-night-line dark:text-cream-dim dark:hover:border-accent-700 dark:hover:text-accent-300',
          ]}
        >
          {c.name}
        </a>
      ))
    }
  </nav>

  {
    posts.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post, i) => (
          <PostCard post={post} priority={i < 3} />
        ))}
      </div>
    ) : (
      <p class="py-20 text-center text-ink-500 dark:text-cream-dim">
        このカテゴリの記事はまだありません。
      </p>
    )
  }
</BaseLayout>
