---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { categories } from '../data/categories';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestPosts = allPosts.slice(0, 6);

// カテゴリごとの記事数
const countByCategory = Object.fromEntries(
  categories.map((c) => [c.slug, allPosts.filter((p) => p.data.category === c.slug).length])
);
---

<BaseLayout title="かえりたくなる部屋 | 暮らしが少し好きになる、モノと部屋の話">
  <!-- ヒーロー -->
  <section class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-accent-600 via-accent-700 to-indigo-800 px-6 py-16 text-white sm:px-12 sm:py-20">
    <div aria-hidden="true" class="absolute inset-0 bg-[radial-gradient(circle_at_80%_10%,rgba(255,255,255,0.2),transparent_50%)]"></div>
    <div aria-hidden="true" class="absolute -bottom-24 -right-24 h-64 w-64 rounded-full bg-white/10 blur-2xl"></div>
    <div class="relative">
      <p class="font-display text-sm font-bold italic tracking-widest text-accent-100">GADGET &amp; INTERIOR BLOG</p>
      <h1 class="mt-3 text-3xl font-extrabold leading-tight tracking-tight sm:text-5xl">
        暮らしが少し好きになる、<br />モノと部屋の話。
      </h1>
      <p class="mt-4 max-w-xl text-sm leading-relaxed text-accent-50/90 sm:text-base">
        ガジェットとインテリアを中心に、買ってよかったもの・部屋づくりの記録を正直に書いていく。
      </p>
      <div class="mt-8">
        <a
          href="/blog"
          class="inline-block rounded-full bg-white px-6 py-3 text-sm font-bold text-accent-700 shadow-lg transition hover:-translate-y-0.5 hover:shadow-xl"
        >
          記事を読む →
        </a>
      </div>
    </div>
  </section>

  <!-- カテゴリ -->
  <section class="mt-16">
    <SectionTitle en="Categories" ja="カテゴリから探す" />
    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
      {
        categories.map((cat) => (
          <a
            href={`/category/${cat.slug}/`}
            class="group flex flex-col items-center gap-2 rounded-2xl border border-slate-200 bg-white p-6 text-center transition hover:-translate-y-1 hover:border-accent-300 hover:shadow-lg dark:border-slate-800 dark:bg-slate-900 dark:hover:border-accent-700"
          >
            <span class="text-3xl transition group-hover:scale-110">{cat.emoji}</span>
            <span class="text-sm font-bold text-slate-800 transition group-hover:text-accent-600 dark:text-slate-200 dark:group-hover:text-accent-400">
              {cat.name}
            </span>
            <span class="text-xs text-slate-400 dark:text-slate-500">{countByCategory[cat.slug]}件</span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- 最新記事 -->
  <section class="mt-16">
    <SectionTitle en="New Posts" ja="最新記事" />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
    <div class="mt-10 text-center">
      <a
        href="/blog"
        class="inline-block rounded-full border-2 border-accent-600 px-8 py-3 text-sm font-bold text-accent-600 transition hover:bg-accent-600 hover:text-white dark:border-accent-400 dark:text-accent-400 dark:hover:bg-accent-500 dark:hover:text-white"
      >
        すべての記事を見る
      </a>
    </div>
  </section>
</BaseLayout>
