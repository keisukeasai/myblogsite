---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import heroImage from '../assets/home/home-hero.jpg';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SectionTitle from '../components/SectionTitle.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { categories } from '../data/categories';
import { site, activeSocials } from '../data/site';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = allPosts.filter((p) => p.data.featured);
const mainFeatured = featured[0];
const subFeatured = featured.slice(1, 3);
const latestPosts = allPosts.slice(0, 6);
const hasSocial = activeSocials().length > 0;

const countByCategory = Object.fromEntries(
  categories.map((c) => [c.slug, allPosts.filter((p) => p.data.category === c.slug).length])
);
const fmt = (d: Date) => d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${site.name} | ${site.tagline}`}>
  <!-- ① Hero(自宅写真のメインビジュアル + テキストオーバーレイ) -->
  <section class="relative isolate mt-2 overflow-hidden rounded-3xl sm:mt-4">
    <Image
      src={heroImage}
      alt="黒い収納扉と観葉植物のある、かえるの自宅リビング"
      widths={[640, 960, 1280, 1920]}
      sizes="(min-width: 1152px) 1088px, 100vw"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 -z-10 h-full w-full object-cover object-[30%_center] sm:object-[center_44%]"
    />
    <!-- 可読性のための最小限のグラデーション(左寄り。写真全体は暗くしない) -->
    <div
      class="absolute inset-0 -z-10 bg-gradient-to-r from-ink-900/85 via-ink-900/50 to-ink-900/20 sm:from-ink-900/70 sm:via-ink-900/35 sm:to-transparent"
    >
    </div>
    <div class="flex min-h-[24rem] items-center px-6 py-16 sm:min-h-[32rem] sm:px-12 lg:min-h-[36rem] lg:px-16">
      <div class="max-w-xl text-left [text-shadow:0_1px_12px_rgba(0,0,0,0.45)]">
        <h1 class="text-4xl font-bold leading-[1.3] tracking-tight text-white drop-shadow-sm sm:text-6xl sm:leading-[1.2]">
          <span class="block whitespace-nowrap">帰りたくなる</span>
          <span class="block whitespace-nowrap">毎日を。</span>
        </h1>
        <p class="mt-5 text-sm leading-loose text-cream/90 sm:text-base">
          <span class="block whitespace-nowrap">ガジェットとインテリアで、</span>
          <span class="block whitespace-nowrap">毎日の暮らしを少し心地よく。</span>
        </p>
        <div class="mt-8">
          <a
            href="/blog"
            class="inline-flex rounded-full bg-cream px-6 py-3.5 text-sm font-medium text-ink-900 shadow-sm transition hover:-translate-y-0.5 hover:bg-white sm:px-8"
          >
            記事を読む
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 補助導線(ファーストビュー直下) -->
  <div class="mt-4 text-center sm:mt-5">
    <a
      href="/founder"
      class="text-sm font-medium text-ink-500 underline-offset-4 transition hover:text-accent-700 hover:underline dark:text-cream-dim dark:hover:text-accent-300"
    >
      運営者について
    </a>
  </div>

  <!-- ② 編集方針(静かなステートメント。カードにせず、ページ背景に溶け込ませる) -->
  <section class="my-16 sm:my-24">
    <div class="max-w-2xl border-l-2 border-accent-300 pl-5 sm:pl-6 dark:border-accent-700">
      <p class="font-display text-xs font-semibold uppercase tracking-[0.2em] text-accent-600 dark:text-accent-300">
        OUR POINT OF VIEW
      </p>
      <h2 class="mt-3 text-xl font-semibold leading-relaxed tracking-tight text-ink-900 sm:text-2xl dark:text-cream">
        <span class="block">「便利だから」ではなく、</span>
        <span class="block">毎日が少し心地よくなるものを。</span>
      </h2>
      <p class="mt-5 text-sm leading-loose text-ink-600 sm:text-[15px] dark:text-cream-dim">
        <span class="block">使ってわかったことも、買う前に迷ったことも。</span>
        <span class="block">ガジェットとインテリアを通して、疲れて帰る毎日を整える記録を、正直に綴ります。</span>
      </p>
    </div>
  </section>

  <!-- ③ おすすめ記事 -->
  {
    mainFeatured && (
      <section class="mt-16 sm:mt-24">
        <SectionTitle en="Pick Up" ja="おすすめの記事" align="left" />
        <a
          href={`/blog/${mainFeatured.id}/`}
          class="group grid overflow-hidden rounded-3xl border border-line bg-surface transition hover:-translate-y-0.5 hover:shadow-lg sm:grid-cols-2 dark:border-night-line dark:bg-night-surface"
        >
          <div class="relative aspect-[16/10] overflow-hidden bg-accent-50 sm:aspect-auto dark:bg-night-line">
            {mainFeatured.data.image ? (
              <Image
                src={mainFeatured.data.image}
                alt=""
                widths={[480, 768, 960]}
                sizes="(min-width: 640px) 50vw, 92vw"
                loading="eager"
                class="thumb-zoom h-full w-full object-cover"
              />
            ) : (
              <div class="thumb-zoom flex h-full min-h-56 w-full items-center justify-center">
                <CategoryIcon
                  slug={mainFeatured.data.category}
                  class="h-16 w-16 text-ink-400 opacity-40 dark:text-cream-dim"
                />
              </div>
            )}
          </div>
          <div class="flex flex-col justify-center p-6 sm:p-10">
            <CategoryBadge
              slug={mainFeatured.data.category}
              variant="line"
              iconClass="h-4 w-4"
              class="w-fit rounded-full bg-accent-50 px-3 py-1 text-xs font-medium text-accent-700 dark:bg-night-line dark:text-accent-300"
            />
            <h3 class="mt-4 text-xl font-bold leading-relaxed text-ink-900 transition-colors group-hover:text-accent-700 sm:text-2xl dark:text-cream dark:group-hover:text-accent-300">
              {mainFeatured.data.title}
            </h3>
            <p class="mt-3 line-clamp-3 text-sm leading-loose text-ink-600 dark:text-cream-dim">
              {mainFeatured.data.description}
            </p>
            <time datetime={mainFeatured.data.pubDate.toISOString()} class="mt-4 text-xs text-ink-500 dark:text-cream-dim">
              {fmt(mainFeatured.data.pubDate)}
            </time>
          </div>
        </a>
        {subFeatured.length > 0 && (
          <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {subFeatured.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        )}
      </section>
    )
  }

  <!-- ④ 最新記事 -->
  <section class="mt-16 sm:mt-24">
    <SectionTitle en="Latest" ja="最新の記事" href="/blog" linkLabel="すべての記事" align="left" />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {latestPosts.map((post, i) => <PostCard post={post} priority={i < 3} />)}
    </div>
  </section>

  <!-- ⑤ カテゴリー(単色線画 + 余白中心。枠・背景塗り・影なし) -->
  <section class="mt-16 sm:mt-24">
    <SectionTitle en="Categories" ja="カテゴリから探す" align="left" />
    <ul class="grid grid-cols-2 gap-x-4 gap-y-9 md:grid-cols-3 xl:grid-cols-6">
      {
        categories.map((cat) => (
          <li>
            <a
              href={`/category/${cat.slug}/`}
              class="group flex min-h-11 flex-col items-center gap-2.5 rounded-xl px-2 py-3 text-center text-ink-900 transition duration-300 hover:-translate-y-0.5 hover:text-accent-700 dark:text-cream dark:hover:text-accent-300"
            >
              <CategoryIcon slug={cat.slug} class="h-14 w-14" />
              <span class="text-sm font-semibold underline-offset-4 group-hover:underline">
                {cat.name}
              </span>
              <span class="text-xs font-medium text-ink-400 dark:text-cream-dim">
                {countByCategory[cat.slug]}件
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- ⑥ SNS / 楽天ROOM 導線 -->
  <section class="mt-16 rounded-3xl border border-line bg-surface px-6 py-14 text-center sm:mt-24 sm:px-12 dark:border-night-line dark:bg-night-surface">
    <p class="font-display text-xs font-semibold uppercase tracking-[0.2em] text-accent-600 dark:text-accent-300">
      Follow
    </p>
    <h2 class="mt-3 text-xl font-bold tracking-tight text-ink-900 sm:text-2xl dark:text-cream">
      暮らしのヒントを、日々お届け
    </h2>
    <p class="mx-auto mt-3 max-w-md text-sm leading-loose text-ink-500 dark:text-cream-dim">
      使ってよかったモノや部屋づくりの記録は、各SNS・RSSでも発信しています。
    </p>
    <div class="mt-7 flex flex-col items-center gap-4">
      {hasSocial && <SocialLinks variant="labeled" class="justify-center" />}
      <a
        href="/rss.xml"
        class="inline-flex items-center gap-1.5 rounded-full border border-line px-5 py-2 text-sm font-medium text-ink-600 transition hover:border-accent-300 hover:text-accent-700 dark:border-night-line dark:text-cream-dim dark:hover:border-accent-700 dark:hover:text-accent-300"
      >
        📡 RSSで購読する
      </a>
    </div>
  </section>
</BaseLayout>
