---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SectionTitle from '../components/SectionTitle.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { getCategory, categories } from '../data/categories';
import { site, activeSocials } from '../data/site';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = allPosts.filter((p) => p.data.featured);
const mainFeatured = featured[0];
const subFeatured = featured.slice(1, 3);
const latestPosts = allPosts.slice(0, 6);
const hasSocial = activeSocials().length > 0;

const countByCategory = Object.fromEntries(
  categories.map((c) => [c.slug, allPosts.filter((p) => p.data.category === c.slug).length])
);
const fmt = (d: Date) => d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${site.name} | ${site.tagline}`}>
  <!-- ① Hero -->
  <section class="pb-8 pt-6 text-center sm:pb-16 sm:pt-14">
    <p class="font-display text-xs font-semibold uppercase tracking-[0.25em] text-accent-600 dark:text-accent-300">
      {site.label}
    </p>
    <h1 class="mx-auto mt-6 max-w-3xl text-3xl font-bold leading-[1.5] tracking-tight text-ink-900 sm:text-5xl sm:leading-[1.4] dark:text-cream">
      帰りたくなる毎日を。
    </h1>
    <p class="mx-auto mt-6 max-w-xl text-sm leading-loose text-ink-500 sm:text-base dark:text-cream-dim">
      ガジェットとインテリアを通して、暮らしが少し豊かになる体験を。<br class="hidden sm:block" />
      ここは商品を売る場所ではなく、毎日を整えるためのメディアです。
    </p>
    <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/blog"
        class="rounded-full bg-ink-900 px-7 py-3 text-sm font-medium text-paper shadow-sm transition hover:-translate-y-0.5 hover:bg-ink-700 dark:bg-cream dark:text-night dark:hover:bg-white"
      >
        記事を読む
      </a>
      <a
        href="/founder"
        class="rounded-full border border-line px-7 py-3 text-sm font-medium text-ink-700 transition hover:border-accent-300 hover:text-accent-700 dark:border-night-line dark:text-cream dark:hover:border-accent-700 dark:hover:text-accent-300"
      >
        運営者について
      </a>
    </div>
  </section>

  <!-- ② ブランド紹介 -->
  <section class="my-8 rounded-3xl bg-accent-50 px-6 py-14 text-center sm:my-16 sm:px-12 dark:bg-night-surface">
    <p class="mx-auto max-w-2xl text-lg font-medium leading-loose text-ink-800 sm:text-xl sm:leading-loose dark:text-cream">
      「便利だから」ではなく、<br class="sm:hidden" />
      <span class="text-accent-700 dark:text-accent-300">“毎日が少し心地よくなるか”</span>。
    </p>
    <p class="mx-auto mt-5 max-w-xl text-sm leading-loose text-ink-500 dark:text-cream-dim">
      その視点だけを頼りに、実際に使ってよかったモノと、
      心地よい部屋づくりの記録を、正直に綴っていきます。
    </p>
  </section>

  <!-- ③ おすすめ記事 -->
  {
    mainFeatured && (
      <section class="mt-16 sm:mt-24">
        <SectionTitle en="Pick Up" ja="おすすめの記事" align="left" />
        <a
          href={`/blog/${mainFeatured.id}/`}
          class="group grid overflow-hidden rounded-3xl border border-line bg-surface transition hover:-translate-y-0.5 hover:shadow-lg sm:grid-cols-2 dark:border-night-line dark:bg-night-surface"
        >
          <div class="relative aspect-[16/10] overflow-hidden bg-accent-50 sm:aspect-auto dark:bg-night-line">
            {mainFeatured.data.image ? (
              <Image
                src={mainFeatured.data.image}
                alt=""
                widths={[480, 768, 960]}
                sizes="(min-width: 640px) 50vw, 92vw"
                loading="eager"
                class="thumb-zoom h-full w-full object-cover"
              />
            ) : (
              <div class="thumb-zoom flex h-full min-h-56 w-full items-center justify-center">
                <span aria-hidden="true" class="text-6xl opacity-25 grayscale">
                  {getCategory(mainFeatured.data.category)?.emoji}
                </span>
              </div>
            )}
          </div>
          <div class="flex flex-col justify-center p-6 sm:p-10">
            <CategoryBadge
              slug={mainFeatured.data.category}
              class="w-fit rounded-full bg-accent-50 px-3 py-1 text-xs font-medium text-accent-700 dark:bg-night-line dark:text-accent-300"
            />
            <h3 class="mt-4 text-xl font-bold leading-relaxed text-ink-900 transition-colors group-hover:text-accent-700 sm:text-2xl dark:text-cream dark:group-hover:text-accent-300">
              {mainFeatured.data.title}
            </h3>
            <p class="mt-3 line-clamp-3 text-sm leading-loose text-ink-600 dark:text-cream-dim">
              {mainFeatured.data.description}
            </p>
            <time datetime={mainFeatured.data.pubDate.toISOString()} class="mt-4 text-xs text-ink-500 dark:text-cream-dim">
              {fmt(mainFeatured.data.pubDate)}
            </time>
          </div>
        </a>
        {subFeatured.length > 0 && (
          <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {subFeatured.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        )}
      </section>
    )
  }

  <!-- ④ 最新記事 -->
  <section class="mt-16 sm:mt-24">
    <SectionTitle en="Latest" ja="最新の記事" href="/blog" linkLabel="すべての記事" align="left" />
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {latestPosts.map((post, i) => <PostCard post={post} priority={i < 3} />)}
    </div>
  </section>

  <!-- ⑤ カテゴリー -->
  <section class="mt-16 sm:mt-24">
    <SectionTitle en="Categories" ja="カテゴリから探す" />
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4">
      {
        categories.map((cat) => (
          <a
            href={`/category/${cat.slug}/`}
            class="group flex flex-col items-center gap-2 rounded-2xl border border-line bg-surface px-4 py-7 text-center transition hover:-translate-y-0.5 hover:border-accent-300 hover:shadow-md dark:border-night-line dark:bg-night-surface dark:hover:border-accent-700"
          >
            <span class="text-3xl transition-transform duration-300 group-hover:scale-110">{cat.emoji}</span>
            <span class="text-sm font-bold text-ink-800 transition-colors group-hover:text-accent-700 dark:text-cream dark:group-hover:text-accent-300">
              {cat.name}
            </span>
            <span class="text-xs text-ink-500 dark:text-cream-dim">{countByCategory[cat.slug]}件</span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ⑥ SNS / 楽天ROOM 導線 -->
  <section class="mt-16 rounded-3xl border border-line bg-surface px-6 py-14 text-center sm:mt-24 sm:px-12 dark:border-night-line dark:bg-night-surface">
    <p class="font-display text-xs font-semibold uppercase tracking-[0.2em] text-accent-600 dark:text-accent-300">
      Follow
    </p>
    <h2 class="mt-3 text-xl font-bold tracking-tight text-ink-900 sm:text-2xl dark:text-cream">
      暮らしのヒントを、日々お届け
    </h2>
    <p class="mx-auto mt-3 max-w-md text-sm leading-loose text-ink-500 dark:text-cream-dim">
      使ってよかったモノや部屋づくりの記録は、各SNS・RSSでも発信しています。
    </p>
    <div class="mt-7 flex flex-col items-center gap-4">
      {hasSocial && <SocialLinks variant="labeled" class="justify-center" />}
      <a
        href="/rss.xml"
        class="inline-flex items-center gap-1.5 rounded-full border border-line px-5 py-2 text-sm font-medium text-ink-600 transition hover:border-accent-300 hover:text-accent-700 dark:border-night-line dark:text-cream-dim dark:hover:border-accent-700 dark:hover:text-accent-300"
      >
        📡 RSSで購読する
      </a>
    </div>
  </section>
</BaseLayout>
