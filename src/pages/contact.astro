---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { site } from '../data/site';

// メールアドレスは site.ts で一元管理(ページ内やフッターに直書きしない)。
const email = site.contact.email;
const description =
  '「かえりたくなる部屋」へのご意見、記事内容についてのご連絡、商品紹介・取材などのお問い合わせ窓口です。';
---

<BaseLayout title={`お問い合わせ｜${site.name}`} description={description}>
  <div class="mx-auto max-w-reading">
    <Breadcrumb items={[{ name: 'ホーム', href: '/' }, { name: 'お問い合わせ' }]} />

    <header>
      <h1 class="text-2xl font-bold tracking-tight text-ink-900 sm:text-3xl dark:text-cream">
        お問い合わせ
      </h1>
    </header>

    <div class="mt-8 text-[15px] leading-loose text-ink-700 dark:text-cream-dim">
      <p>
        「かえりたくなる部屋」へのご意見やご連絡は、メールで受け付けています。
        記事内容についてお気づきの点、商品紹介・取材などのご相談、その他のお問い合わせは、下記のメールアドレスまでお送りください。
      </p>

      <section class="mt-10">
        <h2 class="text-lg font-bold tracking-tight text-ink-900 dark:text-cream">メールアドレス</h2>
        <div class="mt-4 border-l-2 border-accent-300 bg-accent-50/60 py-4 pl-5 pr-4 dark:border-accent-700 dark:bg-night-surface">
          <p class="select-all break-all font-medium text-ink-900 dark:text-cream">{email}</p>
          <a
            href={`mailto:${email}`}
            class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-accent-700 underline-offset-4 transition hover:underline dark:text-accent-300"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16v12H4zM4 7l8 6 8-6" />
            </svg>
            メールを送る
          </a>
        </div>
        <p class="mt-3 text-sm text-ink-500 dark:text-cream-dim">
          メールソフトが開かない場合は、上記のアドレスをコピーしてご利用ください。
        </p>
      </section>

      <section class="mt-10">
        <h2 class="text-lg font-bold tracking-tight text-ink-900 dark:text-cream">返信について</h2>
        <p class="mt-4">
          内容を確認のうえ、必要に応じて返信します。すべてのお問い合わせへの返信をお約束するものではありませんので、あらかじめご了承ください。
        </p>
      </section>

      <section class="mt-10">
        <h2 class="text-lg font-bold tracking-tight text-ink-900 dark:text-cream">
          商品紹介・取材などをご検討の方へ
        </h2>
        <p class="mt-4">
          商品提供や依頼の有無にかかわらず、掲載をお約束するものではありません。
          紹介する場合も、実際に確認できた内容をもとに、メリットだけでなく気になる点も含めて正直にお伝えします。広告・PR・アフィリエイトに該当する場合は、その旨を分かる形で明記します。
        </p>
        <p class="mt-4">
          お問い合わせの際は、商品・サービスの概要、公式サイト、希望する内容をご記載ください。
        </p>
      </section>

      <section class="mt-10">
        <h2 class="text-lg font-bold tracking-tight text-ink-900 dark:text-cream">個人情報の取り扱い</h2>
        <p class="mt-4">
          お問い合わせで受け取った情報は、内容の確認と返信のために使用します。詳しくは<a
            href="/privacy/"
            class="text-accent-700 underline underline-offset-4 transition hover:text-accent-800 dark:text-accent-300 dark:hover:text-accent-200"
            >プライバシーポリシー</a
          >をご確認ください。
        </p>
      </section>
    </div>
  </div>
</BaseLayout>
