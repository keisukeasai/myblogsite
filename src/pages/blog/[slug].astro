---
import { Image, getImage } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CategoryBadge from '../../components/CategoryBadge.astro';
import CategoryIcon from '../../components/CategoryIcon.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import ArticleCta from '../../components/ArticleCta.astro';
import AuthorCard from '../../components/AuthorCard.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getCategory } from '../../data/categories';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const index = allPosts.findIndex((p) => p.id === post.id);
const newerPost = index > 0 ? allPosts[index - 1] : null;
const olderPost = index < allPosts.length - 1 ? allPosts[index + 1] : null;

const readingMinutes = Math.max(1, Math.ceil((post.body?.length ?? 0) / 500));
const cover = post.data.image;
const cat = getCategory(post.data.category);
const updated = post.data.updatedDate;

const siteUrl = Astro.site ?? new URL('http://localhost:4321');
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;

let ogImage: string | undefined;
if (cover) {
  const optimized = await getImage({ src: cover, width: 1200 });
  ogImage = optimized.src;
}

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.data.title,
    description: post.data.description,
    inLanguage: site.lang,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: (updated ?? post.data.pubDate).toISOString(),
    ...(ogImage ? { image: new URL(ogImage, siteUrl).href } : {}),
    author: { '@type': 'Person', name: site.author.name, url: new URL('/founder', siteUrl).href },
    publisher: { '@id': `${siteUrl.href}#organization` },
    mainEntityOfPage: pageUrl,
    articleSection: cat?.name,
    keywords: post.data.tags.join(', '),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl.href },
      { '@type': 'ListItem', position: 2, name: cat?.name, item: new URL(`/category/${post.data.category}/`, siteUrl).href },
      { '@type': 'ListItem', position: 3, name: post.data.title, item: pageUrl },
    ],
  },
];

const dateFmt = (d: Date) => d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title={`${post.data.title} | ${site.name}`}
  description={post.data.description}
  image={ogImage}
  imageAlt={post.data.imageAlt}
  type="article"
  jsonLd={jsonLd}
>
  <!-- ヘッダー部(リーディング幅) -->
  <div class="mx-auto max-w-reading">
    <Breadcrumb
      items={[
        { name: 'ホーム', href: '/' },
        { name: cat?.name ?? '', href: `/category/${post.data.category}/` },
        { name: post.data.title },
      ]}
    />

    {
      cover ? (
        <Image
          src={cover}
          alt={post.data.imageAlt ?? ''}
          widths={[480, 768, 1120]}
          sizes="(min-width: 768px) 704px, 92vw"
          loading="eager"
          fetchpriority="high"
          class="w-full rounded-3xl"
        />
      ) : (
        <div class="flex aspect-[16/9] items-center justify-center rounded-3xl bg-accent-50 dark:bg-night-surface">
          <CategoryIcon slug={post.data.category} class="h-20 w-20 text-ink-400 opacity-40 dark:text-cream-dim" />
        </div>
      )
    }

    <header class="mt-8">
      <div class="flex flex-wrap items-center gap-3 text-sm text-ink-500 dark:text-cream-dim">
        <a
          href={`/category/${post.data.category}/`}
          class="rounded-full bg-accent-600 px-3 py-1 text-xs font-medium text-paper transition hover:bg-accent-700"
        >
          <CategoryBadge slug={post.data.category} variant="line" iconClass="h-4 w-4" />
        </a>
        <time datetime={post.data.pubDate.toISOString()} class="font-medium">{dateFmt(post.data.pubDate)}</time>
        {updated && <span class="text-ink-500 dark:text-cream-dim">(更新: {dateFmt(updated)})</span>}
        <span aria-hidden="true">·</span>
        <span>約{readingMinutes}分で読めます</span>
      </div>
      <h1 class="mt-4 text-2xl font-bold leading-relaxed tracking-tight text-ink-900 sm:text-4xl sm:leading-snug dark:text-cream">
        {post.data.title}
      </h1>
      {
        post.data.tags.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2">
            {post.data.tags.map((tag) => (
              <span class="rounded-full border border-line px-3 py-1 text-xs text-ink-500 dark:border-night-line dark:text-cream-dim">
                #{tag}
              </span>
            ))}
          </div>
        )
      }
    </header>
  </div>

  <!-- 本文 + 目次(デスクトップは追従サイドバー) -->
  <div class="mx-auto mt-12 grid max-w-6xl grid-cols-1 gap-12 lg:grid-cols-[minmax(0,44rem)_14rem] lg:justify-center">
    <div class="min-w-0">
      <!-- モバイル目次 -->
      <details class="mb-8 rounded-2xl border border-line bg-surface p-5 lg:hidden dark:border-night-line dark:bg-night-surface" open>
        <summary class="cursor-pointer font-display text-xs font-semibold uppercase tracking-[0.15em] text-accent-600 dark:text-accent-300">
          目次
        </summary>
        <div class="mt-3">
          <TableOfContents headings={headings} showTitle={false} />
        </div>
      </details>

      <div class="prose prose-neutral max-w-none leading-loose dark:prose-invert prose-headings:font-bold prose-headings:tracking-tight prose-headings:scroll-mt-24 prose-h2:mt-14 prose-h2:border-b prose-h2:border-line prose-h2:pb-3 prose-a:text-accent-700 prose-a:decoration-accent-300 prose-blockquote:border-l-accent-300 prose-blockquote:text-ink-600 prose-code:rounded prose-code:bg-accent-50 prose-code:px-1.5 prose-code:py-0.5 prose-code:font-normal prose-code:before:content-none prose-code:after:content-none prose-img:rounded-2xl dark:prose-a:text-accent-300 dark:prose-h2:border-night-line dark:prose-code:bg-night-surface dark:prose-blockquote:text-cream-dim">
        <Content />
      </div>

      <ArticleCta />
      <AuthorCard />
    </div>

    <aside class="hidden lg:block">
      <div class="sticky top-24">
        <TableOfContents headings={headings} />
      </div>
    </aside>
  </div>

  <!-- 前後の記事 -->
  <div class="mx-auto max-w-reading">
    <nav class="mt-16 grid gap-4 border-t border-line pt-10 sm:grid-cols-2 dark:border-night-line" aria-label="前後の記事">
      {
        newerPost ? (
          <a
            href={`/blog/${newerPost.id}/`}
            class="group rounded-2xl border border-line p-5 transition hover:border-accent-300 hover:shadow-md dark:border-night-line dark:hover:border-accent-700"
          >
            <span class="text-xs font-medium text-ink-500 dark:text-cream-dim">← 新しい記事</span>
            <p class="mt-1.5 line-clamp-2 text-sm font-bold text-ink-900 transition-colors group-hover:text-accent-700 dark:text-cream dark:group-hover:text-accent-300">
              {newerPost.data.title}
            </p>
          </a>
        ) : (
          <div />
        )
      }
      {
        olderPost && (
          <a
            href={`/blog/${olderPost.id}/`}
            class="group rounded-2xl border border-line p-5 text-right transition hover:border-accent-300 hover:shadow-md dark:border-night-line dark:hover:border-accent-700"
          >
            <span class="text-xs font-medium text-ink-500 dark:text-cream-dim">古い記事 →</span>
            <p class="mt-1.5 line-clamp-2 text-sm font-bold text-ink-900 transition-colors group-hover:text-accent-700 dark:text-cream dark:group-hover:text-accent-300">
              {olderPost.data.title}
            </p>
          </a>
        )
      }
    </nav>
  </div>

  <!-- 関連記事 -->
  <div class="mx-auto max-w-5xl">
    <RelatedPosts current={post} posts={allPosts} />
  </div>
</BaseLayout>
