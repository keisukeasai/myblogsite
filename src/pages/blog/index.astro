---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { categories } from '../../data/categories';
import { site } from '../../data/site';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const siteUrl = Astro.site ?? new URL('http://localhost:4321');
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl.href },
      { '@type': 'ListItem', position: 2, name: '記事一覧', item: new URL('/blog/', siteUrl).href },
    ],
  },
];
---

<BaseLayout title={`記事一覧 | ${site.name}`} description={`${site.name}のすべての記事。${site.description}`} jsonLd={jsonLd}>
  <Breadcrumb items={[{ name: 'ホーム', href: '/' }, { name: '記事一覧' }]} />

  <header class="mb-10">
    <p class="font-display text-xs font-semibold uppercase tracking-[0.2em] text-accent-600 dark:text-accent-300">
      All Posts
    </p>
    <h1 class="mt-1.5 text-2xl font-bold tracking-tight text-ink-900 sm:text-3xl dark:text-cream">
      記事一覧
      <span class="ml-2 text-base font-medium text-ink-500 dark:text-cream-dim">{posts.length}件</span>
    </h1>
  </header>

  <!-- カテゴリフィルター -->
  <nav class="mb-10 flex flex-wrap gap-2" aria-label="カテゴリで絞り込み">
    <span class="rounded-full bg-ink-900 px-4 py-1.5 text-sm font-medium text-paper dark:bg-cream dark:text-night">
      すべて
    </span>
    {
      categories.map((cat) => (
        <a
          href={`/category/${cat.slug}/`}
          class="rounded-full border border-line px-4 py-1.5 text-sm font-medium text-ink-600 transition hover:border-accent-300 hover:text-accent-700 dark:border-night-line dark:text-cream-dim dark:hover:border-accent-700 dark:hover:text-accent-300"
        >
          {cat.name}
        </a>
      ))
    }
  </nav>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {posts.map((post, i) => <PostCard post={post} priority={i < 3} />)}
  </div>
</BaseLayout>
