---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// 記事中のキャプション付き画像。MDXで:
//   import photo from './images/photo.jpg';
//   <Figure src={photo} alt="..." caption="..." />
interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="not-prose my-8">
  <Image
    src={src}
    alt={alt}
    widths={[480, 768, 1120]}
    sizes="(min-width: 768px) 704px, 92vw"
    class="w-full rounded-2xl border border-line dark:border-night-line"
  />
  {
    caption && (
      <figcaption class="mt-3 text-center text-xs leading-relaxed text-ink-500 dark:text-cream-dim">
        {caption}
      </figcaption>
    )
  }
</figure>
