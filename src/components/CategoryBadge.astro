---
import { getCategory } from '../data/categories';
import CategoryIcon from './CategoryIcon.astro';

interface Props {
  slug: string;
  class?: string;
  /** アイコン表現。'line'(既定・トップと同じ線画マスク) / 'none'(名称のみ) */
  variant?: 'line' | 'none';
  /** line 表示時のアイコンサイズ(Tailwind の h-/w- クラス) */
  iconClass?: string;
}

const { slug, class: className = '', variant = 'line', iconClass = 'h-4 w-4' } = Astro.props;
const cat = getCategory(slug);
---

{
  cat && (
    <span class={`inline-flex items-center gap-1 ${className}`}>
      {variant === 'line' && <CategoryIcon slug={cat.slug} class={`${iconClass} shrink-0`} />}
      <span>{cat.name}</span>
    </span>
  )
}
