---
// 表示用パンくず。JSON-LD(BreadcrumbList)は各ページで組み立て BaseLayout に渡す。
interface Crumb {
  name: string;
  href?: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav aria-label="パンくずリスト" class="mb-8 text-xs text-ink-500 dark:text-cream-dim">
  <ol class="flex flex-wrap items-center gap-1.5">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-1.5">
          {item.href && i < items.length - 1 ? (
            <a href={item.href} class="transition hover:text-accent-700 dark:hover:text-accent-300">
              {item.name}
            </a>
          ) : (
            <span aria-current="page" class="text-ink-500 dark:text-cream">
              {item.name}
            </span>
          )}
          {i < items.length - 1 && <span aria-hidden="true">/</span>}
        </li>
      ))
    }
  </ol>
</nav>
