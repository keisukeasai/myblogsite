---
// カテゴリ一覧用アイコン。ImageGen 原案から抽出した透過PNGを CSS マスクとして表示し、
// 色は background-color: currentColor で親リンクの文字色(ライト/ダーク/ホバー)に追従させる。
// PNG は public/category-icons/ に原本のまま配置(再圧縮・再生成なし)。装飾のため aria-hidden。
import type { CategorySlug } from '../data/categories';

interface Props {
  slug: CategorySlug;
  class?: string;
}
const { slug, class: className } = Astro.props;

// slug → ImageGen 透過PNGマスク(public 配下の配信パス)
const masks: Record<CategorySlug, string> = {
  gadget: '/category-icons/category-gadget-mask.png',
  interior: '/category-icons/category-interior-mask.png',
  desk: '/category-icons/category-desk-mask.png',
  storage: '/category-icons/category-storage-mask.png',
  review: '/category-icons/category-review-mask.png',
  life: '/category-icons/category-life-mask.png',
};
const url = masks[slug];
---

<span
  class:list={['cat-mask', className]}
  aria-hidden="true"
  style={`-webkit-mask-image:url("${url}");mask-image:url("${url}")`}
></span>

<style>
  .cat-mask {
    display: inline-block;
    /* マスクの不透明部(=原案の線画)が現在の文字色で描かれる */
    background-color: currentColor;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
  }
</style>
