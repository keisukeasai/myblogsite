---
import { activeSocials } from '../data/site';

interface Props {
  /** icon: ゴースト調のテキストリンク / labeled: ボーダー付きチップ */
  variant?: 'icon' | 'labeled';
  class?: string;
}

const { variant = 'icon', class: className = '' } = Astro.props;
const socials = activeSocials();

// 公式ロゴ素材を安全に利用できないため、絵文字ではなく統一した単色テキストで表示する。
const linkClass =
  variant === 'labeled'
    ? 'inline-flex items-center rounded-full border border-line px-4 py-1.5 text-sm font-medium text-ink-700 transition hover:border-accent-300 hover:text-accent-700 dark:border-night-line dark:text-cream dark:hover:border-accent-700 dark:hover:text-accent-300'
    : 'inline-flex items-center rounded-full px-3 py-1.5 text-sm font-medium text-ink-600 transition hover:bg-accent-50 hover:text-accent-700 dark:text-cream-dim dark:hover:bg-night-surface dark:hover:text-accent-300';
---

{
  socials.length > 0 && (
    <ul class:list={['flex flex-wrap items-center gap-2', className]}>
      {socials.map((s) => (
        <li>
          <a href={s.url} target="_blank" rel="me noopener noreferrer" aria-label={s.label} title={s.label} class={linkClass}>
            {s.label}
          </a>
        </li>
      ))}
    </ul>
  )
}
