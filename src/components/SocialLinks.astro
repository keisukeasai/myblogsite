---
import { activeSocials } from '../data/site';

interface Props {
  /** icon: ゴースト調のテキストリンク / labeled: ボーダー付きチップ */
  variant?: 'icon' | 'labeled';
  class?: string;
}

const { variant = 'icon', class: className = '' } = Astro.props;
const socials = activeSocials();

// 公式ロゴ素材を安全に利用できないため、絵文字ではなく統一した単色テキストで表示する。
const linkClass =
  variant === 'labeled'
    ? 'inline-flex items-center rounded-full border border-line px-4 py-1.5 text-sm font-medium text-ink-700 transition hover:border-accent-300 hover:text-accent-700 dark:border-night-line dark:text-cream dark:hover:border-accent-700 dark:hover:text-accent-300'
    : 'inline-flex items-center rounded-full px-3 py-1.5 text-sm font-medium text-ink-600 transition hover:bg-accent-50 hover:text-accent-700 dark:text-cream-dim dark:hover:bg-night-surface dark:hover:text-accent-300';
---

{
  socials.length > 0 && (
    <ul class:list={['flex flex-wrap items-center gap-2', className]}>
      {socials.map((s) => (
        <li>
          <a href={s.url} target="_blank" rel="me noopener noreferrer" aria-label={s.label} title={s.label} class={linkClass}>
            {s.key === 'note' ? (
              /* note 公式ワードマーク(提供素材・形状無改変、単色 currentColor で表示) */
              <svg viewBox="64 56 486 112" class="h-4 w-auto" fill="currentColor" role="img" aria-hidden="true">
                <path d="M129.6 69.1C111.6 68.6 86.4 69.6 68.1 69.6V163.2H94.3V92.4C94.3 92.4 117.6 91.6 126 92.6C133.9 93.5 136.8 98.4 137.1 108.6C137.3 120.2 137.1 126.3 137.1 163.2H163.3C163.3 163.2 163.6 121 163.3 106.3C162.9 80.2 153.8 69.7 129.6 69.1Z" />
                <path d="M250.8 68.8C224.9 68.8 203.8 90 203.8 116.1C203.8 142.2 224.9 163.4 250.8 163.4C276.7 163.4 297.8 142.2 297.8 116.1C297.8 90 276.7 68.8 250.8 68.8ZM250.8 140.8C237.2 140.8 226.2 129.7 226.2 116C226.2 102.3 237.2 91.2 250.8 91.2C264.4 91.2 275.4 102.3 275.4 116C275.4 129.8 264.4 140.8 250.8 140.8Z" />
                <path d="M545.4 116.1C545.4 90 524.3 68.8 498.4 68.8C472.5 68.8 451.4 90 451.4 116.1C451.4 131.4 458.4 144.5 469.3 153.2C476.9 159.2 487.5 163.4 501.7 163.4C508.6 163.4 526.5 161.5 539.4 147.2L528.8 133C524.3 137 513 142.6 504 142.6C492.6 142.6 485.7 140.4 480.7 135.7C477.6 132.9 475.4 128.6 474.4 123.3H544.7C545.1 120.9 545.4 118.6 545.4 116.1ZM474.6 107.5C477.2 96.4 485 88.2 498.3 88.2C512.2 88.2 519.5 97 521.9 107.5H474.6Z" />
                <path d="M386.8 60.1H362.3V86.4H337.1V109.4H362.3V136.7H386.8V109.4H412V86.4H386.8V60.1Z" />
              </svg>
            ) : s.key === 'threads' ? (
              /* Threads 公式ロゴ(提供素材・形状無改変、単色 currentColor で表示) */
              <svg viewBox="0 0 976.98 1082" class="h-4 w-auto" role="img" aria-hidden="true" fill="currentColor">
                <path d="M770.35,500.35c-1.35-156.85-86.39-251.37-230.02-251.37-95.87,0-176.5,43.36-218.85,112.47l92.82,64.71c24.05-37.94,57.25-69.45,118.23-69.45,68.77,0,104.34,38.28,114.5,109.42-33.2-5.08-66.4-7.79-100.61-7.79-185.65,0-273.05,84.02-273.05,195.13s87.4,179.55,216.14,179.55c141.27,0,225.62-95.19,260.18-213.09,35.91,16.26,60.64,54.2,60.64,111.12,0,152.45-175.82,235.45-324.88,235.45-219.86,0-363.5-144.32-363.5-379.08,0-287.62,190.05-471.91,445.48-471.91,171.42,0,256.11,75.21,313.7,176.16l94.86-66.4C913.31,94.5,773.4,1,563.36,1,228.65,1,1,238.48,1,583.01c0,315.06,222.91,497.99,488.51,497.99,219.52,0,441.42-128.05,441.42-347.24,0-114.5-65.72-190.39-160.58-233.41h0ZM485.44,718.85c-48.44,0-91.13-23.04-91.13-65.38,0-66.74,81.98-87.06,162.27-87.06,30.49,0,60.3,2.03,86.72,7.79-18.97,86.72-75.21,144.66-157.87,144.66h0Z" />
              </svg>
            ) : (
              s.label
            )}
          </a>
        </li>
      ))}
    </ul>
  )
}
