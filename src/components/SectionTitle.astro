---
interface Props {
  en: string;
  ja: string;
  /** 右側に表示する補助リンク(任意) */
  href?: string;
  linkLabel?: string;
  align?: 'center' | 'left';
}

const { en, ja, href, linkLabel, align = 'center' } = Astro.props;
---

<div
  class:list={[
    'mb-10 flex flex-wrap items-end gap-x-4 gap-y-2',
    align === 'center' ? 'flex-col items-center text-center' : 'justify-between',
  ]}
>
  <div class={align === 'center' ? '' : 'min-w-0'}>
    <p class="font-display text-xs font-semibold uppercase tracking-[0.2em] text-accent-600 dark:text-accent-300">
      {en}
    </p>
    <h2 class="mt-1.5 text-xl font-bold tracking-tight text-ink-900 sm:text-2xl dark:text-cream">
      {ja}
    </h2>
  </div>
  {
    href && (
      <a
        href={href}
        class="text-sm font-medium text-accent-700 transition hover:text-accent-800 dark:text-accent-300 dark:hover:text-accent-200"
      >
        {linkLabel ?? 'すべて見る'} →
      </a>
    )
  }
</div>
