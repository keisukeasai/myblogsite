---
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';

interface Props {
  current: CollectionEntry<'blog'>;
  posts: CollectionEntry<'blog'>[];
  limit?: number;
}

const { current, posts, limit = 3 } = Astro.props;

// 関連度スコア: 同カテゴリ +10、共通タグ +2/件。同点は新しい順。
const scored = posts
  .filter((p) => p.id !== current.id)
  .map((p) => {
    let score = p.data.category === current.data.category ? 10 : 0;
    score += p.data.tags.filter((t) => current.data.tags.includes(t)).length * 2;
    return { post: p, score };
  })
  .sort((a, b) => b.score - a.score || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, limit)
  .map((s) => s.post);
---

{
  scored.length > 0 && (
    <section class="mt-16" aria-label="関連記事">
      <div class="mb-6">
        <p class="font-display text-xs font-semibold uppercase tracking-[0.15em] text-accent-600 dark:text-accent-300">
          Related
        </p>
        <h2 class="mt-1 text-lg font-bold text-ink-900 dark:text-cream">あわせて読みたい</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {scored.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </section>
  )
}
