---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { pickGradient } from '../utils/thumb';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const cover = post.data.image;
const gradient = pickGradient(post.id);
const initial = post.data.title.charAt(0);
---

<article
  class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:border-accent-300 hover:shadow-xl hover:shadow-accent-600/10 dark:border-slate-800 dark:bg-slate-900 dark:hover:border-accent-700"
>
  <a href={`/blog/${post.id}/`} class="block">
    <div class="relative aspect-[52/30] overflow-hidden">
      {cover ? (
        <Image
          src={cover}
          alt={post.data.imageAlt ?? ''}
          class="thumb-zoom h-full w-full object-cover"
        />
      ) : (
        <div class={`thumb-zoom flex h-full w-full items-center justify-center bg-gradient-to-br ${gradient}`}>
          <span aria-hidden="true" class="select-none font-display text-8xl font-black italic text-white/25">
            {initial}
          </span>
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_75%_20%,rgba(255,255,255,0.25),transparent_45%)]"></div>
        </div>
      )}
      {post.data.tags.length > 0 && (
        <span class="absolute left-3 top-3 rounded-full bg-black/30 px-3 py-1 text-xs font-medium text-white backdrop-blur-sm">
          #{post.data.tags[0]}
        </span>
      )}
    </div>
    <div class="p-5">
      <time datetime={post.data.pubDate.toISOString()} class="text-xs font-medium tracking-wide text-slate-500 dark:text-slate-400">
        {post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h3 class="mt-1.5 line-clamp-2 text-base font-bold leading-snug text-slate-900 transition group-hover:text-accent-600 dark:text-white dark:group-hover:text-accent-400">
        {post.data.title}
      </h3>
      <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
        {post.data.description}
      </p>
    </div>
  </a>
</article>
