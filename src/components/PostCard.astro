---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { getCategory } from '../data/categories';
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  /** 記事一覧の先頭など、優先読み込みしたい場合 true(LCP対策) */
  priority?: boolean;
}

const { post, priority = false } = Astro.props;
const cover = post.data.image;
const cat = getCategory(post.data.category);
---

<article
  class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-surface transition duration-300 hover:-translate-y-0.5 hover:shadow-md dark:border-night-line dark:bg-night-surface"
>
  <a href={`/blog/${post.id}/`} class="flex flex-1 flex-col focus:outline-none">
    <div class="relative aspect-[16/10] overflow-hidden bg-accent-50 dark:bg-night-line">
      {
        cover ? (
          <Image
            src={cover}
            alt=""
            widths={[320, 480, 640]}
            sizes="(min-width: 1024px) 360px, (min-width: 640px) 45vw, 90vw"
            loading={priority ? 'eager' : 'lazy'}
            class="thumb-zoom h-full w-full object-cover"
          />
        ) : (
          <div class="thumb-zoom flex h-full w-full items-center justify-center">
            <span aria-hidden="true" class="select-none text-6xl opacity-25 grayscale">
              {cat?.emoji}
            </span>
          </div>
        )
      }
      <CategoryBadge
        slug={post.data.category}
        class="absolute left-3 top-3 rounded-full bg-paper/85 px-3 py-1 text-xs font-medium text-ink-700 backdrop-blur-sm dark:bg-night/80 dark:text-cream"
      />
    </div>

    <div class="flex flex-1 flex-col p-5">
      <time
        datetime={post.data.pubDate.toISOString()}
        class="text-xs font-medium tracking-wide text-ink-500 dark:text-cream-dim"
      >
        {post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h3
        class="mt-2 line-clamp-2 text-base font-bold leading-relaxed text-ink-900 transition-colors group-hover:text-accent-700 dark:text-cream dark:group-hover:text-accent-300"
      >
        {post.data.title}
      </h3>
      <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-ink-500 dark:text-cream-dim">
        {post.data.description}
      </p>
    </div>
  </a>
</article>
