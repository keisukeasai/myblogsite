---
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Logo from '../components/Logo.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { categories } from '../data/categories';
import { site, activeSocials } from '../data/site';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown>[];
  noindex?: boolean;
}

const { title, description, image, imageAlt, type, jsonLd, noindex } = Astro.props;
const year = new Date().getFullYear();
const hasSocial = activeSocials().length > 0;

const navLinks = [
  { href: '/', label: 'ホーム' },
  { href: '/blog', label: '記事' },
  { href: '/founder', label: '運営者' },
];
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <BaseHead {title} {description} {image} {imageAlt} {type} {jsonLd} {noindex} />
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-paper font-sans text-ink-700 antialiased dark:bg-night dark:text-cream">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-full focus:bg-ink-900 focus:px-5 focus:py-2.5 focus:text-sm focus:font-medium focus:text-paper"
    >
      本文へスキップ
    </a>

    <header class="sticky top-0 z-50 border-b border-line/70 bg-paper/92 backdrop-blur-md dark:border-night-line/70 dark:bg-night/92">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8">
        <a href="/" class="text-ink-900 transition-opacity hover:opacity-70 dark:text-cream" aria-label={`${site.name} ホーム`}>
          <Logo class="h-11 w-auto" />
        </a>

        <!-- デスクトップナビ -->
        <div class="hidden items-center gap-1 md:flex">
          <nav class="flex items-center gap-1 text-sm" aria-label="メインナビゲーション">
            {
              navLinks.map((l) => (
                <a
                  href={l.href}
                  class="rounded-full px-4 py-2 text-ink-600 transition hover:bg-accent-50 hover:text-accent-700 dark:text-cream-dim dark:hover:bg-night-surface dark:hover:text-accent-300"
                >
                  {l.label}
                </a>
              ))
            }
          </nav>
          {hasSocial && <SocialLinks variant="icon" class="ml-1 border-l border-line pl-2 dark:border-night-line" />}
        </div>

        <!-- モバイルメニュー(CSSトグル) -->
        <div class="md:hidden">
          <input type="checkbox" id="mobile-menu" class="peer sr-only" aria-label="メニューを開閉" />
          <label
            for="mobile-menu"
            class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-full text-ink-700 transition hover:bg-accent-50 dark:text-cream dark:hover:bg-night-surface"
          >
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
            </svg>
            <span class="sr-only">メニュー</span>
          </label>

          <div class="invisible fixed inset-x-0 top-16 z-40 max-h-[calc(100vh-4rem)] origin-top overflow-y-auto border-b border-line bg-paper opacity-0 shadow-lg transition peer-checked:visible peer-checked:opacity-100 dark:border-night-line dark:bg-night">
            <nav class="mx-auto max-w-6xl px-5 py-6" aria-label="モバイルナビゲーション">
              <div class="flex flex-col gap-1">
                {
                  navLinks.map((l) => (
                    <a href={l.href} class="rounded-xl px-4 py-3 text-base font-medium text-ink-800 transition hover:bg-accent-50 hover:text-accent-700 dark:text-cream dark:hover:bg-night-surface dark:hover:text-accent-300">
                      {l.label}
                    </a>
                  ))
                }
              </div>
              <p class="mt-5 px-4 text-xs font-semibold tracking-wider text-ink-500 dark:text-cream-dim">CATEGORY</p>
              <div class="mt-2 grid grid-cols-2 gap-1">
                {
                  categories.map((cat) => (
                    <a href={`/category/${cat.slug}/`} class="rounded-xl px-4 py-2.5 text-sm text-ink-700 transition hover:bg-accent-50 hover:text-accent-700 dark:text-cream dark:hover:bg-night-surface dark:hover:text-accent-300">
                      {cat.emoji} {cat.name}
                    </a>
                  ))
                }
              </div>
              {hasSocial && <SocialLinks variant="labeled" class="mt-6 px-4" />}
            </nav>
          </div>
        </div>
      </div>
    </header>

    <main id="main" class="mx-auto w-full max-w-6xl px-5 py-14 sm:px-8 sm:py-20">
      <slot />
    </main>

    <footer class="mt-10 border-t border-line bg-paper dark:border-night-line dark:bg-night">
      <div class="mx-auto max-w-6xl px-5 py-14 sm:px-8">
        <div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
          <div class="max-w-sm">
            <a href="/" class="text-ink-900 transition-opacity hover:opacity-70 dark:text-cream" aria-label={`${site.name} ホーム`}>
              <Logo class="h-9 w-auto" />
            </a>
            <p class="mt-4 text-sm leading-relaxed text-ink-500 dark:text-cream-dim">
              {site.tagline}<br />
              ガジェットとインテリアで、毎日の暮らしを少し心地よく。
            </p>
            {hasSocial && <SocialLinks variant="icon" class="mt-5" />}
          </div>

          <nav class="grid grid-cols-2 gap-x-10 gap-y-2 text-sm" aria-label="カテゴリ">
            <span class="col-span-2 mb-1 text-xs font-semibold tracking-wider text-ink-500 dark:text-cream-dim">CATEGORY</span>
            {
              categories.map((cat) => (
                <a href={`/category/${cat.slug}/`} class="text-ink-600 transition hover:text-accent-700 dark:text-cream-dim dark:hover:text-accent-300">
                  {cat.emoji} {cat.name}
                </a>
              ))
            }
          </nav>

          <nav class="flex flex-col gap-2 text-sm" aria-label="サイト情報">
            <span class="mb-1 text-xs font-semibold tracking-wider text-ink-500 dark:text-cream-dim">ABOUT</span>
            <a href="/founder" class="text-ink-600 transition hover:text-accent-700 dark:text-cream-dim dark:hover:text-accent-300">運営者について</a>
            <a href="/contact" class="text-ink-600 transition hover:text-accent-700 dark:text-cream-dim dark:hover:text-accent-300">お問い合わせ</a>
            <a href="/privacy" class="text-ink-600 transition hover:text-accent-700 dark:text-cream-dim dark:hover:text-accent-300">プライバシーポリシー</a>
            <a href="/rss.xml" class="text-ink-600 transition hover:text-accent-700 dark:text-cream-dim dark:hover:text-accent-300">RSS</a>
          </nav>
        </div>

        <p class="mt-12 border-t border-line pt-6 text-center text-xs text-ink-500 dark:border-night-line dark:text-cream-dim">
          &copy; {year} {site.name}
        </p>
      </div>
    </footer>
  </body>
</html>
